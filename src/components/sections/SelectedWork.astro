---
import { FLAGSHIPS } from '../../lib/career';
import WorkCard from './WorkCard.tsx';

const meta: Record<string, { tagline: string; metric: string; metricLabel: string; accent: 'violet' | 'mint' | 'pink' }> = {
  globalpredictions: {
    tagline: 'SEC-registered AI financial advisor — built end-to-end, the AI talks to real money.',
    metric: 'First',
    metricLabel: 'engineer · SEC-registered AI advisor',
    accent: 'mint',
  },
  'intuition-ai': {
    tagline: 'Founding-engineer story: model monitoring, before it was a category.',
    metric: '→',
    metricLabel: 'acquired by Domino Data Lab',
    accent: 'violet',
  },
  rippling: {
    tagline: 'YC HRIS, early days. The React work that earned a Dan Abramov tweet.',
    metric: '2016',
    metricLabel: 'production React when production React was rare',
    accent: 'pink',
  },
};
---

<section id="work" class="relative border-t border-white/5 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <header class="mb-16 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p data-reveal style="--i: 0" class="font-mono text-xs uppercase tracking-[0.3em] text-violet-soft">/ selected work</p>
        <h2 data-reveal style="--i: 1" class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl text-balance">
          Three case studies. <span class="text-paper-dim">No filler.</span>
        </h2>
      </div>
      <p data-reveal style="--i: 2" class="max-w-md text-paper-dim">
        Each one walks through the setup, what I owned, the hard problem I solved, and the outcome.
      </p>
    </header>

    <div class="space-y-8">
      {
        FLAGSHIPS.map((node, i) => {
          const m = meta[node.id]!;
          const slug = node.caseStudy?.replace('/work/', '') ?? node.id;
          return (
            <WorkCard
              client:load
              href={node.caseStudy ?? '#'}
              index={i}
              slug={slug}
              total={FLAGSHIPS.length}
              accent={m.accent}
              metric={m.metric}
              metricLabel={m.metricLabel}
              start={node.start}
              end={node.end}
              role={node.role}
              company={node.company.split(' · ')[0]!}
              tagline={m.tagline}
              summary={node.summary}
              tags={node.tags}
            />
          );
        })
      }
    </div>
  </div>
</section>
