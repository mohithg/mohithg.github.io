---
import { CAREER, CAREER_EDGES } from '../../lib/career';

// Layout: assign x,y by hand for a pleasing DAG.
// Coordinate space is a 1200x600 viewBox.
// Order is reverse-chronological (present on the LEFT) so that on mobile
// (where the SVG horizontally scrolls) the user sees the current role
// first, then swipes right to walk back through history.
const POSITIONS: Record<string, { x: number; y: number }> = {
  globalpredictions:{ x: 100,  y: 300 },
  domino:           { x: 320,  y: 300 },
  'intuition-ai':   { x: 540,  y: 300 },
  navya:            { x: 740,  y: 440 },
  rippling:         { x: 740,  y: 160 },
  codebrahma:       { x: 940,  y: 300 },
  athena:           { x: 1120, y: 300 },
};

const yearLabel = (n: typeof CAREER[number]) => {
  const sy = n.start.split('-')[0];
  const ey = n.end === 'present' ? 'now' : n.end.split('-')[0];
  return sy === ey ? sy : `${sy}–${ey}`;
};
---

<section id="career" class="relative overflow-hidden border-t border-white/5 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <header class="mb-12 max-w-3xl">
      <p data-reveal style="--i: 0" class="font-mono text-xs uppercase tracking-[0.3em] text-mint">/ career.dag</p>
      <h2 data-reveal style="--i: 1" class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl text-balance">
        Eleven years, rendered as a <span class="gradient-text-anim">directed acyclic graph</span>.
      </h2>
      <p data-reveal style="--i: 2" class="mt-5 text-lg text-paper-dim text-pretty">
        It's how I think about systems. And, it turns out, how my career has run too.
        Hover any node for the receipts.
      </p>
    </header>

    <div class="relative">
      <!-- Glow -->
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div class="mesh-bg absolute -inset-20 opacity-30"></div>
      </div>

      <!-- Frame -->
      <div data-reveal data-reveal-scale style="--i: 3" class="relative rounded-2xl border border-white/5 bg-ink-2/40 p-2 backdrop-blur-sm sm:p-4">
        <div class="rounded-xl bg-ink-3/40 p-4 sm:p-6">
          <!-- Header bar like an Airflow DAG view -->
          <div class="mb-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-pink/70"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-mint/70"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-violet/70"></span>
            </div>
            <p class="font-mono text-[11px] text-paper-muted">
              <span class="text-paper-dim">dag_id</span>=mohith_g · <span class="text-paper-dim">schedule</span>=daily · <span class="text-mint">running</span>
            </p>
            <p class="hidden font-mono text-[11px] text-paper-muted sm:block">v11.{new Date().getFullYear() - 2014}</p>
          </div>

          <div class="relative overflow-x-auto" data-dag-scroll data-svg-anim>
            <svg
              data-dag-svg
              viewBox="0 0 1200 600"
              class="min-w-[900px] w-full max-w-none"
              role="img"
              aria-label="Career timeline as a directed acyclic graph"
            >
              <defs>
                <linearGradient id="edge-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#7C5CFF" stop-opacity="0.45"/>
                  <stop offset="50%" stop-color="#7C5CFF" stop-opacity="0.85"/>
                  <stop offset="100%" stop-color="#00E5A0" stop-opacity="0.85"/>
                </linearGradient>
                <linearGradient id="edge-gradient-active" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#A088FF"/>
                  <stop offset="100%" stop-color="#00E5A0"/>
                </linearGradient>
                <radialGradient id="node-glow" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#7C5CFF" stop-opacity="0.4"/>
                  <stop offset="100%" stop-color="#7C5CFF" stop-opacity="0"/>
                </radialGradient>
                <radialGradient id="node-glow-mint" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#00E5A0" stop-opacity="0.5"/>
                  <stop offset="100%" stop-color="#00E5A0" stop-opacity="0"/>
                </radialGradient>
                <pattern id="dotgrid" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
                  <circle cx="1" cy="1" r="0.8" fill="#FFFFFF" fill-opacity="0.06"/>
                </pattern>
              </defs>

              <!-- Background dot grid -->
              <rect x="0" y="0" width="1200" height="600" fill="url(#dotgrid)"/>

              <!-- Edges -->
              {CAREER_EDGES.map(({ from, to }, ei) => {
                const a = POSITIONS[from]!;
                const b = POSITIONS[to]!;
                const cx = (a.x + b.x) / 2;
                return (
                  <g class="svg-edge-anim dag-edge" data-from={from} data-to={to} style={`--i: ${ei}`}>
                    <path
                      class="dag-edge-path"
                      d={`M ${a.x} ${a.y} C ${cx} ${a.y}, ${cx} ${b.y}, ${b.x} ${b.y}`}
                      stroke="url(#edge-gradient)"
                      stroke-width="2"
                      fill="none"
                      stroke-dasharray="4 6"
                    >
                      <animate attributeName="stroke-dashoffset" values="0;-100" dur="6s" repeatCount="indefinite" />
                    </path>
                  </g>
                );
              })}

              <!-- Nodes -->
              {CAREER.map((node, ni) => {
                const pos = POSITIONS[node.id]!;
                const isCurrent = node.end === 'present';
                const isFlagship = !!node.flagship;
                const fill = isCurrent ? '#00E5A0' : isFlagship ? '#7C5CFF' : '#1A1A24';
                const stroke = isCurrent ? '#00E5A0' : isFlagship ? '#7C5CFF' : '#2A2A38';
                return (
                  <g
                    class="dag-node svg-node-anim group"
                    data-node-id={node.id}
                    data-node-role={node.role}
                    data-node-summary={node.summary}
                    data-node-company={node.company}
                    data-node-dates={yearLabel(node)}
                    data-node-flagship={isFlagship ? 'true' : 'false'}
                    data-node-current={isCurrent ? 'true' : 'false'}
                    style={`--i: ${ni}; --x: ${pos.x}; --y: ${pos.y};`}
                  >
                    {(isFlagship || isCurrent) && (
                      <circle class="dag-node-glow" cx={pos.x} cy={pos.y} r="44" fill={isCurrent ? 'url(#node-glow-mint)' : 'url(#node-glow)'} class:list={["opacity-60"]} />
                    )}
                    <a href={node.caseStudy ?? `#career-${node.id}`} class="cursor-pointer">
                      <rect
                        x={pos.x - 88}
                        y={pos.y - 26}
                        width="176"
                        height="52"
                        rx="12"
                        fill={isCurrent || isFlagship ? '#0F0F18' : '#0A0A0F'}
                        stroke={stroke}
                        stroke-opacity={isCurrent || isFlagship ? '0.9' : '0.4'}
                        stroke-width="1"
                        class="transition-all"
                      />
                      <circle cx={pos.x - 72} cy={pos.y - 8} r="3" fill={fill} />
                      <text x={pos.x - 60} y={pos.y - 4} font-family="Geist Mono, monospace" font-size="11" fill="#9B9B9B">{yearLabel(node)}</text>
                      <text x={pos.x - 60} y={pos.y + 14} font-family="Geist Sans, sans-serif" font-size="13" font-weight="600" fill="#F5F5F0">{node.company.split(' · ')[0]}</text>
                    </a>
                  </g>
                );
              })}
            </svg>

            <!-- Hover popover (HTML, positioned over the SVG via JS) -->
            <div
              data-dag-popover
              class="pointer-events-none absolute z-20 hidden w-64 rounded-xl border border-white/10 bg-ink-2/95 p-4 shadow-2xl backdrop-blur-md transition-opacity duration-150"
              style="opacity: 0;"
            >
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-mint">
                <span data-popover-dates></span>
                <span class="mx-2 text-white/20">·</span>
                <span data-popover-role class="text-violet-soft"></span>
              </p>
              <p data-popover-company class="mt-2 font-display text-base font-semibold tracking-tight text-paper"></p>
              <p data-popover-summary class="mt-2 text-xs leading-relaxed text-paper-dim"></p>
              <p class="mt-3 flex items-center gap-1 font-mono text-[10px] uppercase tracking-widest text-paper-muted">
                <span data-popover-cta>click to open the case study</span>
                <span aria-hidden="true">→</span>
              </p>
            </div>
          </div>

          <!-- Legend -->
          <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 border-t border-white/5 pt-4 font-mono text-[11px] text-paper-muted">
            <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-mint"></span> running · today</span>
            <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-violet"></span> flagship</span>
            <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-paper-muted"></span> chapter</span>
            <span class="ml-auto hidden sm:inline">← upstream tasks (the path that led here)</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .dag-node rect {
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 200ms var(--ease-out-soft, ease-out), filter 200ms var(--ease-out-soft, ease-out);
  }
  .dag-node:hover rect {
    transform: translateY(-2px);
    filter: drop-shadow(0 6px 20px rgba(124, 92, 255, 0.45));
  }

  /* Edge / node states driven by JS toggling data-active on the SVG */
  [data-dag-svg] .dag-edge,
  [data-dag-svg] .dag-node {
    transition: opacity 220ms var(--ease-out-soft, ease-out);
  }
  [data-dag-svg] .dag-edge-path {
    transition: stroke-width 200ms var(--ease-out-soft, ease-out), filter 220ms var(--ease-out-soft, ease-out);
  }

  /* When any node is active, dim everything by default */
  [data-dag-svg][data-active] .dag-edge { opacity: 0.18; }
  [data-dag-svg][data-active] .dag-node { opacity: 0.45; }

  /* Then re-light the active node and its connected edges */
  [data-dag-svg][data-active] .dag-node.is-active { opacity: 1; }
  [data-dag-svg][data-active] .dag-edge.is-active { opacity: 1; }
  [data-dag-svg][data-active] .dag-edge.is-active .dag-edge-path {
    stroke: url(#edge-gradient-active);
    stroke-width: 3;
    stroke-dasharray: none;
    filter: drop-shadow(0 0 8px rgba(160, 136, 255, 0.55));
  }

  @media (prefers-reduced-motion: reduce) {
    animate { display: none; }
  }
</style>

<script>
  // 1. On narrow viewports, the DAG SVG scrolls horizontally. Start scrolled
  //    to the LEFT (Global Predictions = current).
  // 2. Hover behavior: highlight related edges, dim everything else, and
  //    show a small HTML popover with the role and summary.
  function initScroll() {
    document.querySelectorAll<HTMLElement>('[data-dag-scroll]').forEach((el) => {
      el.scrollLeft = 0;
    });
  }

  function initHover() {
    const svgRaw = document.querySelector<SVGSVGElement>('[data-dag-svg]');
    const popoverRaw = document.querySelector<HTMLDivElement>('[data-dag-popover]');
    if (!svgRaw || !popoverRaw) return;
    if (svgRaw.dataset.hoverInit === '1') return;
    svgRaw.dataset.hoverInit = '1';
    const svg: SVGSVGElement = svgRaw;
    const popover: HTMLDivElement = popoverRaw;

    const popoverDates = popover.querySelector<HTMLElement>('[data-popover-dates]')!;
    const popoverRole = popover.querySelector<HTMLElement>('[data-popover-role]')!;
    const popoverCompany = popover.querySelector<HTMLElement>('[data-popover-company]')!;
    const popoverSummary = popover.querySelector<HTMLElement>('[data-popover-summary]')!;
    const popoverCta = popover.querySelector<HTMLElement>('[data-popover-cta]')!;
    const container = popover.parentElement!;
    if (!popoverDates || !popoverRole || !popoverCompany || !popoverSummary || !popoverCta || !container) return;

    const nodes = Array.from(svg.querySelectorAll<SVGGElement>('.dag-node'));
    const edges = Array.from(svg.querySelectorAll<SVGGElement>('.dag-edge'));

    function activate(node: SVGGElement) {
      const id = node.dataset.nodeId!;
      svg!.setAttribute('data-active', id);

      nodes.forEach((n) => n.classList.toggle('is-active', n === node));
      edges.forEach((edge) => {
        const from = edge.dataset.from;
        const to = edge.dataset.to;
        edge.classList.toggle('is-active', from === id || to === id);
      });

      popoverDates.textContent = node.dataset.nodeDates ?? '';
      popoverRole.textContent = node.dataset.nodeRole ?? '';
      popoverCompany.textContent = node.dataset.nodeCompany ?? '';
      popoverSummary.textContent = node.dataset.nodeSummary ?? '';
      popoverCta.textContent =
        node.dataset.nodeCurrent === 'true'
          ? 'click to read the PortfolioPilot case study'
          : node.dataset.nodeFlagship === 'true'
          ? 'click to read the case study'
          : 'click for chapter detail';

      const rect = node.getBoundingClientRect();
      const containerRect = container.getBoundingClientRect();
      // Center popover horizontally on node, place 14px below.
      const desiredLeft = rect.left - containerRect.left + rect.width / 2;
      const popoverWidth = 256; // matches w-64
      const left = Math.max(
        12,
        Math.min(desiredLeft - popoverWidth / 2, containerRect.width - popoverWidth - 12)
      );
      const top = rect.bottom - containerRect.top + 14;
      popover.style.left = `${left}px`;
      popover.style.top = `${top}px`;
      popover.classList.remove('hidden');
      requestAnimationFrame(() => {
        popover.style.opacity = '1';
      });
    }

    function deactivate() {
      svg.removeAttribute('data-active');
      nodes.forEach((n) => n.classList.remove('is-active'));
      edges.forEach((e) => e.classList.remove('is-active'));
      popover.style.opacity = '0';
      window.setTimeout(() => {
        popover.classList.add('hidden');
      }, 160);
    }

    nodes.forEach((node) => {
      node.addEventListener('mouseenter', () => activate(node));
      node.addEventListener('mouseleave', deactivate);
      node.addEventListener('focus', () => activate(node));
      node.addEventListener('blur', deactivate);
    });
  }

  function init() {
    initScroll();
    initHover();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>
