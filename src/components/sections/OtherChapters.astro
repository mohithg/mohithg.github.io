---
import { CAREER } from '../../lib/career';
import SpringCard from '../motion/SpringCard.tsx';
const others = CAREER.filter((c) => !c.flagship);
---

<section class="relative border-t border-white/5 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <header class="mb-12 max-w-3xl">
      <p data-reveal style="--i: 0" class="font-mono text-xs uppercase tracking-[0.3em] text-pink">/ the other chapters</p>
      <h2 data-reveal style="--i: 1" class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl text-balance">
        The supporting cast. <span class="text-paper-dim">Each one shaped how I work.</span>
      </h2>
    </header>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-2">
      {
        others.map((node, i) => (
          <SpringCard
            client:load
            index={i}
            accent="pink"
            id={`career-${node.id}`}
            className="group relative overflow-hidden rounded-2xl border border-white/5 bg-ink-2/30 p-6 hover:border-white/15 hover:bg-ink-3/40 sm:p-8"
          >
            <header class="flex items-baseline justify-between gap-4">
              <h3 class="font-display text-xl font-semibold tracking-tight sm:text-2xl">
                {node.company}
              </h3>
              <span class="font-mono text-[11px] uppercase tracking-widest text-paper-muted whitespace-nowrap">
                {node.start.split('-')[0]}–{node.end === 'present' ? 'now' : node.end.split('-')[0]}
              </span>
            </header>
            <p class="mt-1 font-mono text-[12px] text-paper-dim">{node.role}</p>
            <p class="mt-4 text-paper-dim text-pretty">
              {node.summary}
            </p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              {node.tags.map((t) => (
                <span class="rounded-full border border-white/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-paper-muted">
                  {t}
                </span>
              ))}
            </div>
          </SpringCard>
        ))
      }
    </div>
  </div>
</section>
