---
import { ArrowUpRight } from 'lucide-react';
import { PRESS } from '../../lib/press';
---

<section class="relative border-t border-white/5 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <header class="mb-12 max-w-3xl">
      <p data-reveal style="--i: 0" class="font-mono text-xs uppercase tracking-[0.3em] text-violet-soft">/ moments</p>
      <h2 data-reveal style="--i: 1" class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl text-balance">
        A few <span class="gradient-text-anim">landmarks</span> along the way.
      </h2>
    </header>

    <ol class="relative space-y-2 border-l border-white/10 pl-8">
      {
        PRESS.map((p, i) => (
          <li data-reveal data-reveal-slide-l style={`--i: ${i}`} class="group relative">
            <span class="absolute -left-[34px] top-1.5 flex h-3 w-3 items-center justify-center">
              <span class="absolute inline-flex h-full w-full rounded-full bg-violet/30"></span>
              <span class="relative h-1.5 w-1.5 rounded-full bg-violet"></span>
            </span>
            <article class="rounded-xl px-4 py-4 transition-colors group-hover:bg-white/[0.02] sm:px-6 sm:py-5">
              <header class="flex flex-wrap items-baseline gap-3">
                <span class="font-mono text-xs text-mint tabular-nums">{p.year}</span>
                <h3 class="font-display text-lg font-semibold tracking-tight sm:text-xl">
                  {p.title}
                </h3>
                {p.source && (
                  <span class="font-mono text-[11px] uppercase tracking-widest text-paper-muted">· {p.source}</span>
                )}
              </header>
              <p class="mt-2 text-paper-dim text-pretty">{p.description}</p>
              {p.href && (
                <a href={p.href} class="mt-3 inline-flex items-center gap-1 font-mono text-[12px] text-paper-dim transition-colors hover:text-paper">
                  source <ArrowUpRight className="h-3 w-3" />
                </a>
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>
