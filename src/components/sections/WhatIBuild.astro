---
import { BUILD_SURFACES } from '../../lib/build';
import { Sparkles, Workflow, Zap, Layers3, Database, Cpu } from 'lucide-react';
import SpringCard from '../motion/SpringCard.tsx';

const iconNodeMap = {
  sparkles: Sparkles,
  workflow: Workflow,
  zap: Zap,
  layers: Layers3,
  database: Database,
  cpu: Cpu,
};
---

<section class="relative border-t border-white/5 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <header class="mb-16 max-w-3xl">
      <p data-reveal style="--i: 0" class="font-mono text-xs uppercase tracking-[0.3em] text-mint">/ what i build</p>
      <h2 data-reveal style="--i: 1" class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl text-balance">
        Six surfaces. <span class="text-paper-dim">All of them shipped, in production.</span>
      </h2>
      <p data-reveal style="--i: 2" class="mt-5 text-lg text-paper-dim text-pretty">
        I'm a Product Engineer. I don't get squeamish about which layer of the stack I'm in —
        the question is always <em class="not-italic text-paper">what does the product need next?</em>
      </p>
    </header>

    <div class="grid gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 lg:grid-cols-3">
      {
        BUILD_SURFACES.map((s, i) => {
          const Icon = iconNodeMap[s.iconName];
          return (
            <SpringCard client:load index={i} accent="violet" lift={false} className="group relative bg-ink-2/60 p-7 transition-colors hover:bg-ink-3/60">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-ink-3/60 transition-transform group-hover:scale-110 group-hover:border-violet/40">
                  <Icon className="h-4 w-4 text-violet-soft transition-transform group-hover:rotate-6" />
                </span>
                <span class="font-mono text-[10px] uppercase tracking-widest text-paper-muted">
                  /{s.id}
                </span>
              </div>
              <h3 class="mt-5 font-display text-xl font-semibold tracking-tight">{s.title}</h3>
              <p class="mt-2 text-sm text-paper-dim text-pretty">{s.blurb}</p>
              <ul class="mt-5 space-y-1.5 border-t border-white/5 pt-5 text-sm text-paper-dim">
                {s.examples.map((ex) => (
                  <li class="flex gap-2 text-pretty">
                    <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-violet/60"></span>
                    <span>{ex}</span>
                  </li>
                ))}
              </ul>
            </SpringCard>
          );
        })
      }
    </div>
  </div>
</section>
