---
import { ArrowRight, ArrowLeft } from 'lucide-react';
type Props = {
  prev?: { href: string; title: string };
  next?: { href: string; title: string };
};
const { prev, next } = Astro.props;
---

<nav class="mt-16 grid gap-3 border-t border-white/5 pt-10 sm:grid-cols-2">
  {prev ? (
    <a href={prev.href} class="group flex items-center justify-between rounded-xl border border-white/10 bg-ink-2/40 px-5 py-4 transition-colors hover:bg-ink-3/40">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-widest text-paper-muted">previous</p>
        <p class="mt-1 font-display text-lg font-semibold tracking-tight">{prev.title}</p>
      </div>
      <ArrowLeft className="h-5 w-5 text-paper-dim transition-transform group-hover:-translate-x-1 group-hover:text-paper" />
    </a>
  ) : <span aria-hidden="true"></span>}
  {next ? (
    <a href={next.href} class="group flex items-center justify-between rounded-xl border border-white/10 bg-ink-2/40 px-5 py-4 transition-colors hover:bg-ink-3/40">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-widest text-paper-muted">next</p>
        <p class="mt-1 font-display text-lg font-semibold tracking-tight">{next.title}</p>
      </div>
      <ArrowRight className="h-5 w-5 text-paper-dim transition-transform group-hover:translate-x-1 group-hover:text-paper" />
    </a>
  ) : <span aria-hidden="true"></span>}
</nav>
