---
type Props = {
  title: string;
};
const { title } = Astro.props;
---

<section class="relative my-16 overflow-hidden rounded-2xl border border-white/10 bg-ink-2/30 p-8 sm:p-12">
  <div class="pointer-events-none absolute -top-24 -right-24 h-64 w-64 rounded-full bg-violet/10 blur-3xl"></div>
  <p class="font-mono text-xs uppercase tracking-[0.3em] text-pink">/ a hard problem, solved</p>
  <h3 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl text-balance">
    {title}
  </h3>
  <div class="prose prose-invert mt-6 max-w-3xl prose-p:text-paper-dim prose-p:text-pretty prose-strong:text-paper prose-em:text-mint prose-em:not-italic prose-code:text-violet-soft prose-code:font-normal prose-li:text-paper-dim">
    <slot />
  </div>
</section>
