---
import Base from './Base.astro';
import { ArrowLeft } from 'lucide-react';
import { SITE } from '../lib/site';

type FM = {
  title: string;
  tagline: string;
  role: string;
  start: string;
  end: string;
  accent?: 'violet' | 'mint' | 'pink';
  metrics: { value: string; label: string }[];
  description?: string;
};
type Props = FM & { frontmatter?: FM };

// MDX `layout: ...` passes the frontmatter as `Astro.props.frontmatter`.
// Also support direct prop usage from .astro pages.
const fm: FM = (Astro.props as Props).frontmatter ?? (Astro.props as FM);
const { title, tagline, role, start, end, accent = 'violet', metrics, description } = fm;
const accentText = accent === 'mint' ? 'text-mint' : accent === 'pink' ? 'text-pink' : 'text-violet-soft';
const accentBg = accent === 'mint' ? 'bg-mint/10' : accent === 'pink' ? 'bg-pink/10' : 'bg-violet/10';

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: tagline,
  author: { '@type': 'Person', name: SITE.name, url: SITE.url },
  publisher: { '@type': 'Person', name: SITE.name, url: SITE.url },
  datePublished: '2026-05-02',
  mainEntityOfPage: new URL(Astro.url.pathname, SITE.url).toString(),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Work', item: `${SITE.url}/#work` },
    { '@type': 'ListItem', position: 3, name: title, item: new URL(Astro.url.pathname, SITE.url).toString() },
  ],
};
---

<Base title={title} description={description ?? tagline} jsonLd={{ ...articleJsonLd, breadcrumb: breadcrumbJsonLd }}>
  <article>
    <!-- Hero -->
    <header class="relative isolate overflow-hidden pt-32 pb-16 sm:pt-40 sm:pb-24">
      <div class:list={['pointer-events-none absolute -top-32 right-0 h-[500px] w-[500px] rounded-full blur-3xl opacity-60', accentBg]}></div>
      <div class="grid-bg pointer-events-none absolute inset-0 -z-10 opacity-20 [mask-image:radial-gradient(ellipse_at_top_right,black_30%,transparent_70%)]"></div>

      <div class="mx-auto max-w-4xl px-5 sm:px-8">
        <a href="/#work" class="group inline-flex items-center gap-1.5 font-mono text-xs text-paper-dim transition-colors hover:text-paper">
          <ArrowLeft className="h-3.5 w-3.5 transition-transform group-hover:-translate-x-0.5" />
          all work
        </a>

        <p class:list={['mt-8 font-mono text-xs uppercase tracking-[0.3em]', accentText]}>
          / case study · {start.split('-')[0]}–{end === 'present' ? 'now' : end.split('-')[0]}
        </p>
        <h1 class="mt-4 font-display text-5xl font-semibold tracking-tight sm:text-6xl lg:text-7xl text-balance">{title}</h1>
        <p class="mt-6 max-w-3xl text-xl text-paper-dim text-pretty">{tagline}</p>
        <p class="mt-3 font-mono text-sm text-paper-muted">{role}</p>

        <dl class="mt-12 grid gap-3 sm:grid-cols-3">
          {metrics.map((m) => (
            <div class="rounded-xl border border-white/10 bg-ink-2/40 px-5 py-4">
              <dt class="font-mono text-[10px] uppercase tracking-widest text-paper-muted">{m.label}</dt>
              <dd class:list={['mt-2 font-display text-2xl font-semibold tracking-tight tabular-nums', accentText]}>{m.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </header>

    <!-- Body -->
    <div class="mx-auto max-w-3xl px-5 pb-32 sm:px-8">
      <div class="prose prose-invert max-w-none
        prose-headings:font-display prose-headings:tracking-tight prose-headings:text-balance
        prose-h2:mt-16 prose-h2:text-3xl prose-h2:font-semibold sm:prose-h2:text-4xl
        prose-h3:mt-10 prose-h3:text-xl prose-h3:font-semibold
        prose-p:text-paper-dim prose-p:text-pretty prose-p:leading-relaxed
        prose-strong:text-paper prose-strong:font-semibold
        prose-em:not-italic prose-em:text-mint
        prose-a:text-paper prose-a:underline prose-a:decoration-violet/40 prose-a:underline-offset-4 hover:prose-a:decoration-violet
        prose-code:text-violet-soft prose-code:font-normal prose-code:bg-ink-2/60 prose-code:rounded prose-code:px-1.5 prose-code:py-0.5 prose-code:before:content-[''] prose-code:after:content-['']
        prose-li:text-paper-dim prose-li:marker:text-violet/60
        prose-blockquote:not-italic prose-blockquote:border-l-violet/60 prose-blockquote:text-paper prose-blockquote:font-normal
        prose-hr:border-white/10
        ">
        <slot />
      </div>
    </div>
  </article>
</Base>
