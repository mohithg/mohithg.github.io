---
import Base from '../layouts/Base.astro';
import Hero from '../components/sections/Hero.astro';
import CareerDag from '../components/sections/CareerDag.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import OtherChapters from '../components/sections/OtherChapters.astro';
import WhatIBuild from '../components/sections/WhatIBuild.astro';
import Press from '../components/sections/Press.astro';
import Contact from '../components/sections/Contact.astro';
import { SITE } from '../lib/site';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  url: SITE.url,
  image: new URL('/og/default.png', SITE.url).toString(),
  jobTitle: 'Product Engineer',
  worksFor: {
    '@type': 'Organization',
    name: 'Global Predictions (PortfolioPilot)',
    url: 'https://portfoliopilot.com',
  },
  alumniOf: [
    { '@type': 'Organization', name: 'Domino Data Lab', url: 'https://dominodatalab.com' },
    { '@type': 'Organization', name: 'IntuitionAI', url: 'https://intuition.ai' },
    { '@type': 'Organization', name: 'Rippling', url: 'https://rippling.com' },
    { '@type': 'Organization', name: 'AthenaHealth', url: 'https://www.athenahealth.com/' },
    { '@type': 'CollegeOrUniversity', name: 'Saveetha Engineering College', url: 'https://saveetha.ac.in', sameAs: 'https://en.wikipedia.org/wiki/Anna_University' },
  ],
  email: `mailto:${SITE.email}`,
  sameAs: [SITE.github, SITE.linkedin, SITE.codepen, SITE.twitter, ...(SITE.blogEnabled ? [SITE.blog] : [])],
  knowsAbout: [
    'Artificial Intelligence',
    'Large Language Models',
    'Quantitative finance',
    'Full-stack engineering',
    'React',
    'Python',
    'TypeScript',
    'Distributed systems',
    'Real-time systems',
    'Kubernetes',
    'AWS',
    'Eval systems',
    'Model monitoring',
  ],
  description: SITE.description,
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  alternateName: 'mohithg.com',
  url: SITE.url,
  inLanguage: 'en',
  author: { '@id': SITE.url + '/#person' },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE.url}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { ...personJsonLd, '@id': SITE.url + '/#person' },
    websiteJsonLd,
  ],
};
---

<Base jsonLd={homeJsonLd}>
  <Hero />
  <CareerDag />
  <SelectedWork />
  <OtherChapters />
  <WhatIBuild />
  <Press />
  <Contact />
</Base>
