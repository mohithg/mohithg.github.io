# Copy to .env (which is git-ignored) for local development.
# In production (Cloudflare Pages), set this in the dashboard's
# Settings → Environment variables.

# Cloudflare Web Analytics beacon token. Get it from the Cloudflare
# dashboard → Web Analytics → your site → "Add a site" → token.
# Tokens are public (they ship in HTML), so it's fine to commit a
# real token to env vars — just don't put it in source.
PUBLIC_CF_ANALYTICS_TOKEN=
